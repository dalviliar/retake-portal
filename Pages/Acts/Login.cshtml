@page
@model RetakePortal.Pages.Acts.LoginModel
@{
    ViewData["Title"] = "Вход — Специалист по актам";
}

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow border-0">
            <div class="card-body p-4">
                <h4 class="text-center mb-1">Специалист по актам</h4>
                <p class="text-center text-muted small mb-4">Вход в систему</p>

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Логин</label>
                        <input asp-for="Username" class="form-control" autocomplete="username" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Пароль</label>
                        <input asp-for="Password" type="password" class="form-control" autocomplete="current-password" />
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
                    }

                    <button type="submit" class="btn btn-primary w-100">Войти</button>
                    <a asp-page="/Index" class="btn btn-link w-100 mt-1 text-muted">← Назад</a>
                </form>
            </div>
        </div>
    </div>
</div>
