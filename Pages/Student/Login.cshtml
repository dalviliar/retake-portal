@page
@model RetakePortal.Pages.Student.LoginModel
@{
    ViewData["Title"] = "Вход — Студент";
}

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow border-0">
            <div class="card-body p-4">
                <h4 class="text-center mb-1">Вход для студента</h4>
                <p class="text-center text-muted small mb-4">Введите ваш ИИН для входа в систему</p>

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">ИИН</label>
                        <input asp-for="IIN" class="form-control form-control-lg text-center"
                               placeholder="Введите ИИН" maxlength="20"
                               autocomplete="off" />
                    </div>

                    @if (Model.HasExistingApplication)
                    {
                        <div class="alert alert-info py-3 text-center">
                            <div class="fw-semibold mb-1">У вас уже есть заявление</div>
                            <div class="small mb-2">Вход в систему недоступен, но вы можете проверить статус вашей заявки.</div>
                            <a asp-page="/Student/Status" asp-route-iin="@Model.IIN"
                               class="btn btn-primary btn-sm w-100">Проверить статус заявки &rarr;</a>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
                    }

                    @if (!Model.HasExistingApplication)
                    {
                        <button type="submit" class="btn btn-primary w-100 mt-1">Войти</button>
                    }
                    <a asp-page="/Index" class="btn btn-link w-100 mt-1 text-muted">← Назад</a>
                </form>
            </div>
        </div>
    </div>
</div>
