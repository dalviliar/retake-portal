@page
@model RetakePortal.Pages.Student.StatusModel
@{
    ViewData["Title"] = "Статус заявок";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <h4 class="fw-bold mb-4">Статус заявлений</h4>

        @if (!Model.Searched)
        {
            <div class="card border-0 shadow-sm mb-4" style="max-width:420px">
                <div class="card-body">
                    <p class="text-muted small mb-3">Введите ИИН для проверки статуса заявки</p>
                    <form method="get">
                        <div class="input-group">
                            <input name="iin" class="form-control" placeholder="Введите ИИН"
                                   maxlength="20" value="@Model.IINInput" />
                            <button class="btn btn-primary" type="submit">Проверить</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else if (!Model.Applications.Any())
        {
            <div class="alert alert-info">Заявлений по ИИН <strong>@Model.IINInput</strong> не найдено.</div>
            <a asp-page="/Student/Status" class="btn btn-outline-secondary btn-sm">Поиск снова</a>
        }
        else
        {
            <p class="text-muted small mb-3">ИИН: <strong>@Model.IINInput</strong></p>
            @foreach (var app in Model.Applications)
            {
                @* Determine route type *@
                bool isFxOnly = app.Items.All(i => i.Grade == "FX");
                bool hasDirectorGrades = app.Items.Any(i => i.Grade is "F" or "I");
                bool isPaid = app.PaymentType == "paid";

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <span class="fw-semibold">Заявление №@app.Id</span>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge @app.StatusBadgeClass">@app.StatusDisplay</span>
                            <small class="text-muted">@app.SubmittedAt.ToAlmaty()</small>
                        </div>
                    </div>
                    <div class="card-body">

                        @* Route progress *@
                        <div class="mb-4">
                            @if (isFxOnly)
                            {
                                @* FX route: Подача → ОР → Одобрено → Пересдача *@
                                var steps = new[] {
                                    ("Подача", new[]{"pending","pending_director","director_approved","pending_payment","payment_submitted","approved","rejected","scheduled"}),
                                    ("Специалист ОР", new[]{"approved","rejected","scheduled"}),
                                    ("Одобрено", new[]{"approved","scheduled"}),
                                    ("Пересдача", new[]{"scheduled"})
                                };
                                <div class="d-flex align-items-center gap-0 mb-1">
                                    @foreach (var (label, activeStatuses) in steps)
                                    {
                                        bool active = activeStatuses.Contains(app.Status);
                                        bool current = label == "Подача" ? app.Status == "pending"
                                            : label == "Специалист ОР" ? app.Status is "pending" or "approved" or "rejected"
                                            : label == "Одобрено" ? app.Status == "approved"
                                            : app.ScheduledAt.HasValue;
                                        <div class="text-center" style="flex:1">
                                            <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center fw-bold"
                                                 style="width:32px;height:32px;background:@(active?"#198754":"#dee2e6");color:@(active?"white":"#6c757d")">
                                                @(active ? "✓" : "·")
                                            </div>
                                            <div class="small mt-1" style="font-size:0.7rem;color:@(active?"#198754":"#6c757d")">@label</div>
                                        </div>
                                        @if (label != "Пересдача")
                                        {
                                            <div style="flex:0.3;height:2px;background:@(active?"#198754":"#dee2e6");margin-bottom:20px"></div>
                                        }
                                    }
                                </div>
                            }
                            else
                            {
                                @* F/I route: Подача → Директор → (Оплата →) Специалист → Пересдача *@
                                var s = app.Status;
                                var routeSteps = isPaid
                                    ? new[] { "Подача", "Директор", "Оплата", "Проверка", "Пересдача" }
                                    : new[] { "Подача", "Директор", "Специалист", "Пересдача" };

                                bool StepDone(string step) => step switch {
                                    "Подача"    => true,
                                    "Директор"  => s is "director_approved" or "pending_payment" or "payment_submitted" or "approved" or "rejected",
                                    "Оплата"    => s is "payment_submitted" or "approved",
                                    "Проверка"  => s == "approved",
                                    "Специалист"=> s == "approved",
                                    "Пересдача" => app.ScheduledAt.HasValue,
                                    _           => false
                                };

                                bool StepCurrent(string step) => step switch {
                                    "Подача"    => s == "pending_director",
                                    "Директор"  => s == "pending_director",
                                    "Оплата"    => s == "pending_payment",
                                    "Проверка"  => s == "payment_submitted",
                                    "Специалист"=> s == "director_approved",
                                    "Пересдача" => s == "approved",
                                    _           => false
                                };

                                <div class="d-flex align-items-center gap-0 mb-1">
                                    @foreach (var step in routeSteps)
                                    {
                                        bool done = StepDone(step);
                                        bool cur  = StepCurrent(step);
                                        string bg    = done ? "#198754" : cur ? "#0d6efd" : "#dee2e6";
                                        string color = (done || cur) ? "white" : "#6c757d";
                                        <div class="text-center" style="flex:1">
                                            <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center fw-bold"
                                                 style="width:32px;height:32px;background:@bg;color:@color">
                                                @(done ? "✓" : cur ? "●" : "·")
                                            </div>
                                            <div class="small mt-1" style="font-size:0.7rem;color:@(done?"#198754":cur?"#0d6efd":"#6c757d")">@step</div>
                                        </div>
                                        @if (step != routeSteps.Last())
                                        {
                                            <div style="flex:0.3;height:2px;background:@(done?"#198754":"#dee2e6");margin-bottom:20px"></div>
                                        }
                                    }
                                </div>
                            }
                        </div>

                        <table class="table table-sm mt-2">
                            <thead class="table-light">
                                <tr>
                                    <th>Дисциплина</th>
                                    <th class="text-center">Оценка</th>
                                    <th class="text-center">Кредиты</th>
                                    <th class="text-end">Сумма</th>
                                    @if (app.Status == "approved") { <th>Дата пересдачи</th> }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in app.Items)
                                {
                                    var sched = Model.RetakeSchedules
                                        .FirstOrDefault(s => s.DisciplineName == item.DisciplineName);
                                    var gradeClass = item.Grade switch {
                                        "F"  => "bg-danger",
                                        "I"  => "bg-info text-dark",
                                        _    => "bg-warning text-dark"
                                    };
                                    <tr>
                                        <td>@item.DisciplineName</td>
                                        <td class="text-center">
                                            <span class="badge @gradeClass">@item.Grade</span>
                                        </td>
                                        <td class="text-center">@item.Credits</td>
                                        <td class="text-end">
                                            @(item.TotalCost == 0 ? "—" : item.TotalCost.ToString("N0") + " тг")
                                        </td>
                                        @if (app.Status == "approved")
                                        {
                                            <td>
                                                @if (sched?.ExamDate != null)
                                                {
                                                    <span class="fw-semibold text-success">
                                                        @sched.ExamDate.Value.ToString("dd.MM.yyyy")
                                                    </span>
                                                    <span class="text-muted small ms-1">
                                                        @sched.StartTime–@sched.EndTime
                                                    </span>
                                                    @if (!string.IsNullOrEmpty(sched.Room))
                                                    {
                                                        <div class="text-muted small">
                                                            @sched.Building, ауд. @sched.Room
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Уточняется</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                            @if (app.TotalAmount > 0)
                            {
                                <tfoot>
                                    <tr class="fw-bold">
                                        <td colspan="3" class="text-end">Итого:</td>
                                        <td class="text-end">@app.TotalAmount.ToString("N0") тг</td>
                                    </tr>
                                </tfoot>
                            }
                        </table>

                        @* Status-specific messages *@
                        @if (app.Status == "pending_director")
                        {
                            <div class="alert alert-info py-2 mt-3 mb-0">
                                <strong>Заявление на рассмотрении у директора.</strong>
                                Ожидайте решения.
                            </div>
                        }
                        else if (app.Status == "pending_payment")
                        {
                            <div class="alert alert-warning py-2 mt-3 mb-2">
                                <strong>Директор одобрил заявление.</strong>
                                Пересдача является <strong>платной</strong>.
                                @if (app.TotalAmount > 0)
                                {
                                    <span>Сумма к оплате: <strong>@app.TotalAmount.ToString("N0") тг</strong>.</span>
                                }
                            </div>
                            <div class="mb-3">
                                <a href="https://kaspi.kz/pay/SatbayevUniversity?started_from=QR"
                                   target="_blank" class="btn btn-warning fw-semibold">
                                    💳 Оплатить через Kaspi
                                </a>
                                <div class="text-muted small mt-1">После оплаты прикрепите чек ниже.</div>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.PaymentError))
                            {
                                <div class="alert alert-danger py-2">@Model.PaymentError</div>
                            }
                            <form method="post" enctype="multipart/form-data">
                                <input type="hidden" name="AppId" value="@app.Id" />
                                @foreach (var item in app.Items)
                                {
                                    <div class="mb-2">
                                        <label class="form-label small fw-semibold">
                                            Чек оплаты — @item.DisciplineName
                                        </label>
                                        <input type="file" name="receipts_@item.DisciplineName"
                                               class="form-control form-control-sm"
                                               accept=".pdf,.jpg,.jpeg,.png" />
                                    </div>
                                }
                                <button type="submit" class="btn btn-primary btn-sm mt-1">
                                    Отправить чек на проверку
                                </button>
                            </form>
                        }
                        else if (app.Status == "payment_submitted")
                        {
                            <div class="alert alert-info py-2 mt-3 mb-0">
                                <strong>Чек отправлен на проверку.</strong>
                                Специалист проверяет оплату и назначит пересдачу.
                            </div>
                        }
                        else if (app.Status == "director_approved")
                        {
                            <div class="alert alert-success py-2 mt-3 mb-0">
                                <strong>Директор одобрил.</strong>
                                Пересдача бесплатная — ожидайте назначения расписания.
                            </div>
                        }
                        else if (app.Status == "approved")
                        {
                            @if (Model.RetakeSchedules.Any(s => app.Items.Any(i => i.DisciplineName == s.DisciplineName && s.ExamDate != null)))
                            {
                                <div class="alert alert-success py-2 mt-3 mb-0">
                                    <strong>Расписание пересдачи назначено.</strong>
                                    Дата и аудитория указаны в таблице выше.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info py-2 mt-3 mb-0">
                                    <strong>Заявление одобрено.</strong>
                                    Пересдачи планируются <strong>28–29 мая 2026 года</strong>.
                                    Точное расписание (дата, время, аудитория) будет доступно
                                    с <strong>18 мая</strong> — следите за обновлениями на этой странице
                                    или в платформе SSO.
                                </div>
                            }
                        }
                        else if (app.Status == "rejected")
                        {
                            <div class="alert alert-danger py-2 mt-3 mb-0">
                                <strong>Заявление отклонено.</strong>
                                @if (!string.IsNullOrEmpty(app.RejectionReason))
                                {
                                    <span> Причина: @app.RejectionReason</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            <a asp-page="/Student/Status" class="btn btn-outline-secondary btn-sm">Поиск снова</a>
        }
    </div>
</div>
