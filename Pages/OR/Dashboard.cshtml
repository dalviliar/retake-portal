@page
@model RetakePortal.Pages.OR.DashboardModel
@{
    ViewData["Title"] = "Заявления — ОР";
}

@if (Model.ExpulsionConflictCount > 0)
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
        <strong>⚠ Внимание:</strong>
        <span>У <strong>@Model.ExpulsionConflictCount</strong> заявл. выявлен конфликт — по дисциплине из заявки имеется акт нарушения. Проверьте и примите решение.</span>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">Все заявления</h4>
    <div class="d-flex gap-2 flex-wrap">
        @{
            var _discParams = string.Join("", Model.DisciplineFilters.Select(d => $"&disciplines={Uri.EscapeDataString(d)}"));
            var _deptParams = string.Join("", Model.DeptFilters.Select(d => $"&depts={Uri.EscapeDataString(d)}"));
        }
        @foreach (var tab in new[] {
            ("", "Все"),
            ("pending", "На рассмотрении"),
            ("pending_director", "У директора"),
            ("director_approved", "Одобрено директором"),
            ("pending_payment", "Ожидает оплаты"),
            ("payment_submitted", "Оплата на проверке"),
            ("approved", "Одобрено"),
            ("rejected", "Отклонено")
        })
        {
            <a href="/OR/Dashboard?status=@tab.Item1@_discParams@_deptParams"
               class="btn btn-sm @(Model.StatusFilter == tab.Item1 ? "btn-primary" : "btn-outline-secondary")">
                @tab.Item2
                @if (tab.Item1 == "" && Model.ActionRequiredCount > 0)
                {
                    <span class="badge bg-danger ms-1">@Model.ActionRequiredCount</span>
                }
            </a>
        }
    </div>
</div>

<div class="mb-3">
    <form method="get" id="filterForm">
        <input type="hidden" name="status" value="@Model.StatusFilter" />
        <div class="d-flex gap-2 align-items-center flex-wrap">

            @* Фильтр по кафедрам *@
            @{
                var allDepts = Model.AllDisciplines.Select(d => d.Department)
                    .Where(d => !string.IsNullOrEmpty(d)).Distinct().OrderBy(d => d).ToList();
            }
            <div class="dropdown">
                <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle"
                        data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                    Кафедра
                    <span id="deptBadge" class="badge bg-primary ms-1" style="display:none"></span>
                </button>
                <div class="dropdown-menu p-2 shadow" style="min-width:380px; max-width:460px">
                    <input type="text" id="deptSearch" class="form-control form-control-sm mb-2"
                           placeholder="Поиск по кафедре..." autocomplete="off" />
                    <div id="deptList" style="max-height:240px; overflow-y:auto; padding-left:1.75rem">
                        @foreach (var dept in allDepts)
                        {
                            var deptId = $"dep_{Math.Abs(dept.GetHashCode())}";
                            <div class="form-check dept-item py-1" data-search="@dept.ToLower()">
                                <input class="form-check-input dept-check" type="checkbox"
                                       name="depts" id="@deptId" value="@dept"
                                       @(Model.DeptFilters.Contains(dept) ? "checked" : "") />
                                <label class="form-check-label small" for="@deptId">@dept</label>
                            </div>
                        }
                    </div>
                    <div class="border-top mt-2 pt-2 d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-primary" id="deptApplyBtn">Применить</button>
                        <a asp-page="/OR/Dashboard" asp-route-status="@Model.StatusFilter"
                           class="btn btn-sm btn-outline-secondary">Сбросить</a>
                    </div>
                </div>
            </div>

            @* Фильтр по дисциплинам *@
            <div class="dropdown">
                <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle"
                        data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                    Дисциплины
                    @if (Model.DisciplineFilters.Any())
                    {
                        <span class="badge bg-primary ms-1">@Model.DisciplineFilters.Count</span>
                    }
                </button>
                <div class="dropdown-menu p-2 shadow" style="min-width:420px; max-width:500px">
                    <input type="text" id="discSearch" class="form-control form-control-sm mb-2"
                           placeholder="Поиск по названию..." autocomplete="off" />
                    <div id="discList" style="max-height:320px; overflow-y:auto; padding-left:1.75rem">
                        @foreach (var group in Model.AllDisciplines.GroupBy(d => d.Department).OrderBy(g => g.Key))
                        {
                            @if (!string.IsNullOrEmpty(group.Key))
                            {
                                <div class="text-muted small fw-semibold mt-2 mb-1 dept-disc-header"
                                     data-dept="@group.Key"
                                     style="margin-left:-1.75rem; padding-left:0.5rem; background:#f8f9fa">
                                    @group.Key
                                </div>
                            }
                            @foreach (var d in group.OrderBy(d => d.Name))
                            {
                                var checkId = $"dc_{Math.Abs(d.Name.GetHashCode())}";
                                <div class="form-check disc-item py-1"
                                     data-dept="@d.Department"
                                     data-search="@d.Display.ToLower() @d.Department.ToLower()">
                                    <input class="form-check-input" type="checkbox"
                                           name="disciplines" value="@d.Name" id="@checkId"
                                           @(Model.DisciplineFilters.Contains(d.Name) ? "checked" : "") />
                                    <label class="form-check-label small" for="@checkId">
                                        @if (!string.IsNullOrEmpty(d.Code))
                                        {
                                            <span class="text-muted font-monospace me-1">@d.Code</span>
                                        }
                                        @d.Name
                                    </label>
                                </div>
                            }
                        }
                    </div>
                    <div class="border-top mt-2 pt-2 d-flex gap-2">
                        <button type="submit" class="btn btn-sm btn-primary">Применить</button>
                        <a asp-page="/OR/Dashboard" asp-route-status="@Model.StatusFilter"
                           class="btn btn-sm btn-outline-secondary">Сбросить</a>
                    </div>
                </div>
            </div>

            @if (Model.DisciplineFilters.Any())
            {
                <span class="text-muted small">
                    Выбрано: @string.Join(", ", Model.DisciplineFilters.Select(d => d.Length > 40 ? d[..40] + "…" : d))
                </span>
            }
        </div>
    </form>
</div>

@section Scripts {
<script>
    // Department search
    document.getElementById('deptSearch').addEventListener('input', function () {
        var q = this.value.toLowerCase();
        document.querySelectorAll('.dept-item').forEach(function (el) {
            el.style.display = el.dataset.search.includes(q) ? '' : 'none';
        });
    });

    // Department filter → show/hide disciplines
    function applyDeptFilter() {
        var checked = Array.from(document.querySelectorAll('.dept-check:checked')).map(c => c.value);
        var badge = document.getElementById('deptBadge');
        badge.textContent = checked.length;
        badge.style.display = checked.length > 0 ? '' : 'none';

        document.querySelectorAll('.disc-item, .dept-disc-header').forEach(function (el) {
            if (checked.length === 0) {
                el.style.display = '';
            } else {
                el.style.display = checked.includes(el.dataset.dept) ? '' : 'none';
                // Uncheck hidden disciplines
                if (!checked.includes(el.dataset.dept)) {
                    var cb = el.querySelector('input[type=checkbox]');
                    if (cb) cb.checked = false;
                }
            }
        });
    }

    document.querySelectorAll('.dept-check').forEach(function (cb) {
        cb.addEventListener('change', applyDeptFilter);
    });

    // Применить кафедры: отметить все дисциплины выбранных кафедр и отправить форму
    document.getElementById('deptApplyBtn').addEventListener('click', function () {
        var checked = Array.from(document.querySelectorAll('.dept-check:checked')).map(c => c.value);
        document.querySelectorAll('.disc-item input[type=checkbox]').forEach(function (cb) {
            var item = cb.closest('.disc-item');
            if (checked.length === 0) {
                cb.checked = false;
            } else {
                cb.checked = checked.includes(item.dataset.dept);
            }
        });
        document.getElementById('filterForm').submit();
    });

    // Apply dept filter on page load (restores state from URL params)
    applyDeptFilter();

    // Discipline search
    document.getElementById('discSearch').addEventListener('input', function () {
        var q = this.value.toLowerCase();
        document.querySelectorAll('.disc-item').forEach(function (el) {
            if (el.style.display === 'none' && q === '') return;
            el.style.display = el.dataset.search.includes(q) ? '' : 'none';
        });
    });
</script>
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <small class="text-muted">
        Найдено: <strong>@Model.TotalCount</strong>
        @if (Model.TotalPages > 1)
        {
            <span>· Страница @Model.CurrentPage из @Model.TotalPages</span>
        }
    </small>
</div>

@if (!Model.Applications.Any())
{
    <div class="text-center text-muted py-5">Заявлений не найдено</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>№</th>
                        <th>ИИН</th>
                        <th>Студент</th>
                        <th>Дисциплины</th>
                        <th class="text-center">Курс</th>
                        <th class="text-center">Дисц.</th>
                        <th class="text-end">Сумма</th>
                        <th class="text-center">Статус</th>
                        <th>Рассмотрел</th>
                        <th>Дата</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.Applications)
                    {
                        <tr>
                            <td class="text-muted small">#@app.Id</td>
                            <td class="font-monospace small">@app.IIN</td>
                            <td>@app.StudentFullName</td>
                            <td class="small">@string.Join(", ", app.Items.Select(i => i.DisciplineDisplay))</td>
                            <td class="text-center">@app.Course</td>
                            <td class="text-center">@app.Items.Count</td>
                            <td class="text-end fw-semibold">@app.TotalAmount.ToString("N0") тг</td>
                            <td class="text-center">
                                <span class="badge @app.StatusBadgeClass">@app.StatusDisplay</span>
                                @if (app.ExpulsionConflict)
                                {
                                    <span class="badge bg-warning text-dark ms-1" title="Акт нарушения">⚠</span>
                                }
                            </td>
                            <td class="small">
                                @if (!string.IsNullOrEmpty(app.ReviewedByName))
                                {
                                    <span>@app.ReviewedByName</span>
                                }
                                else if (!string.IsNullOrEmpty(app.DirectorName))
                                {
                                    <span class="text-muted">@app.DirectorName</span>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="small text-muted">@app.SubmittedAt.ToAlmatyShort()</td>
                            <td>
                                <a asp-page="/OR/ApplicationDetail" asp-route-id="@app.Id"
                                   asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                                   class="btn btn-sm btn-outline-primary">
                                    Открыть
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        var discParams = string.Join("", Model.DisciplineFilters.Select(d => $"&disciplines={Uri.EscapeDataString(d)}"));
        var deptParams = string.Join("", Model.DeptFilters.Select(d => $"&depts={Uri.EscapeDataString(d)}"));
        string PageUrl(int p) => $"/OR/Dashboard?status={Uri.EscapeDataString(Model.StatusFilter)}{discParams}{deptParams}&page={p}";
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center flex-wrap mb-0">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@PageUrl(Model.CurrentPage - 1)">‹</a>
                </li>
                @for (int i = Math.Max(1, Model.CurrentPage - 3); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 3); i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@PageUrl(i)">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@PageUrl(Model.CurrentPage + 1)">›</a>
                </li>
            </ul>
        </nav>
    }
}
