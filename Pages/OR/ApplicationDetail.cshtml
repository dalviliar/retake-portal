@page "{id:int}"
@model RetakePortal.Pages.OR.ApplicationDetailModel
@{
    ViewData["Title"] = $"Заявление №{Model.App?.Id}";
}

@if (Model.App == null)
{
    <div class="alert alert-danger">Заявление не найдено.</div>
    <a asp-page="/OR/Dashboard" class="btn btn-outline-secondary btn-sm">← Назад</a>
    return;
}

<div class="mb-3">
    <a asp-page="/OR/Dashboard" class="text-muted small">← Все заявления</a>
</div>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="fw-bold mb-1">Заявление №@Model.App.Id</h4>
        <span class="badge @Model.App.StatusBadgeClass fs-6">@Model.App.StatusDisplay</span>
    </div>
    <small class="text-muted">@Model.App.SubmittedAt.ToAlmaty() (Алматы)</small>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small mb-3">Данные студента</h6>
                <table class="table table-sm table-borderless mb-0">
                    <tr><td class="text-muted">ИИН</td><td class="font-monospace">@Model.App.IIN</td></tr>
                    <tr><td class="text-muted">ФИО</td><td class="fw-semibold">@Model.App.StudentFullName</td></tr>
                    <tr><td class="text-muted">Институт</td><td>@Model.App.Institute</td></tr>
                    <tr><td class="text-muted">Кафедра</td><td>@Model.App.Department</td></tr>
                    <tr><td class="text-muted">Специальность</td><td>@Model.App.Specialty</td></tr>
                    <tr><td class="text-muted">Курс</td><td>@Model.App.Course</td></tr>
                    <tr><td class="text-muted">Уровень</td><td>@Model.App.EducationLevelDisplay</td></tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small mb-3">Дисциплины</h6>
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Дисциплина</th>
                            <th class="text-center">Оценка</th>
                            <th class="text-end">Сумма</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.App.Items)
                        {
                            var badgeClass = item.Grade switch {
                                "F" => "bg-danger",
                                "I" => "bg-info text-dark",
                                _   => "bg-warning text-dark"
                            };
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.DisciplineCode))
                                    {
                                        <span class="text-muted font-monospace small d-block">@item.DisciplineCode</span>
                                    }
                                    @item.DisciplineName
                                    <div class="mt-1">
                                        @if (!string.IsNullOrEmpty(item.ConfirmationDocumentUrl))
                                        {
                                            <a href="@item.ConfirmationDocumentUrl" target="_blank" class="badge bg-secondary text-decoration-none me-1">
                                                Справка
                                            </a>
                                        }
                                        @if (!string.IsNullOrEmpty(item.PaymentReceiptUrl))
                                        {
                                            <a href="@item.PaymentReceiptUrl" target="_blank" class="badge bg-info text-decoration-none">
                                                Чек
                                            </a>
                                        }
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge @badgeClass">@item.Grade</span>
                                </td>
                                <td class="text-end">
                                    @(item.TotalCost == 0 ? "Бесплатно" : item.TotalCost.ToString("N0") + " тг")
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td colspan="2" class="text-end">Итого:</td>
                            <td class="text-end">
                                @(Model.App.TotalAmount == 0 ? "Бесплатно" : Model.App.TotalAmount.ToString("N0") + " тг")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@if (Model.App.ExpulsionConflict)
{
    <div class="alert alert-warning mb-4">
        <strong>⚠ Конфликт: по одной или нескольким дисциплинам из этой заявки имеется акт нарушения.</strong>
        Проверьте список актов перед принятием решения.
        <a asp-page="/OR/ExpelledStudents" class="alert-link ms-2">Открыть список →</a>
    </div>
}

@if (Model.App.Status == "rejected" && !string.IsNullOrEmpty(Model.App.RejectionReason))
{
    <div class="alert alert-danger mb-4">
        <strong>Причина отклонения:</strong> @Model.App.RejectionReason
    </div>
}

@if (Model.App.Status == "pending_director")
{
    <div class="alert alert-info mb-4">
        <strong>Ожидает согласования директора.</strong> После решения директора заявление вернётся сюда.
    </div>
}

@if (Model.App.Status == "director_approved")
{
    <div class="alert alert-primary mb-4">
        <strong>Директор согласовал.</strong> Примите окончательное решение.
    </div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h6 class="text-muted text-uppercase small mb-3">История рассмотрения</h6>
        <ul class="list-unstyled mb-0">
            <li class="mb-2">
                <span class="badge bg-secondary me-2">Подано</span>
                <span class="small">@Model.App.SubmittedAt.ToAlmaty()</span>
            </li>
            @if (Model.App.ReviewedAt.HasValue && !string.IsNullOrEmpty(Model.App.ReviewedByName))
            {
                var isDir = Model.App.ReviewedByRole == "director";
                <li class="mb-2">
                    <span class="badge @(isDir ? "bg-dark" : "bg-primary") me-2">@(isDir ? "Директор" : "ОР")</span>
                    <span class="small fw-semibold">@Model.App.ReviewedByName</span>
                    <span class="text-muted small ms-2">@Model.App.ReviewedAt.Value.ToAlmaty()</span>
                </li>
            }
            @if (Model.App.DirectorReviewedAt.HasValue && !string.IsNullOrEmpty(Model.App.DirectorName))
            {
                <li class="mb-2">
                    <span class="badge bg-dark me-2">Директор</span>
                    <span class="small fw-semibold">@Model.App.DirectorName</span>
                    <span class="text-muted small ms-2">@Model.App.DirectorReviewedAt.Value.ToAlmaty()</span>
                    <span class="badge @Model.App.StatusBadgeClass ms-2">@Model.App.StatusDisplay</span>
                </li>
            }
            @if (Model.App.ScheduledAt.HasValue && !string.IsNullOrEmpty(Model.App.ScheduledByName))
            {
                <li class="mb-2">
                    <span class="badge bg-success me-2">Пересдача назначена</span>
                    <span class="small fw-semibold">@Model.App.ScheduledByName</span>
                    <span class="text-muted small ms-2">@Model.App.ScheduledAt.Value.ToAlmaty()</span>
                </li>
            }
        </ul>
    </div>
</div>

@if (Model.App.Status == "payment_submitted")
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-3">Проверка оплаты</h6>
            <p class="text-muted small mb-3">
                Студент прикрепил чек(и) об оплате. Чеки доступны в таблице дисциплин выше.
                Проверьте и подтвердите оплату.
            </p>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
            }
            <form method="post">
                <input type="hidden" asp-for="AppId" />
                <div class="d-flex gap-2">
                    <button type="submit" name="decision" value="verify_payment" class="btn btn-success">
                        &#x2713; Оплата подтверждена — одобрить
                    </button>
                    <button type="submit" name="decision" value="rejected" class="btn btn-danger">
                        &#x2715; Отклонить
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@if (Model.App.Status == "approved" && !Model.App.ScheduledAt.HasValue)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-3">Назначение пересдачи</h6>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
            }
            <p class="text-muted small mb-3">Заявление одобрено. Подтвердите назначение пересдачи студенту.</p>
            <form method="post">
                <input type="hidden" asp-for="AppId" />
                @if (Model.App.ExpulsionConflict)
                {
                    <div class="d-flex gap-2">
                        <button type="submit" name="decision" value="schedule" class="btn btn-success btn-sm">
                            &#x2713; Пересдача назначена
                        </button>
                        <button type="submit" name="decision" value="rejected" class="btn btn-danger btn-sm">
                            &#x2715; Отклонить (акт нарушения)
                        </button>
                    </div>
                }
                else
                {
                    <button type="submit" name="decision" value="schedule" class="btn btn-success">
                        &#x2713; Пересдача назначена
                    </button>
                }
            </form>
        </div>
    </div>
}

@if (Model.App.Status is "pending" or "director_approved")
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-3">Принять решение</h6>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
            }

            <form method="post">
                <input type="hidden" asp-for="AppId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Причина (обязательна при отклонении)</label>
                    <textarea asp-for="Reason" class="form-control" rows="3"
                              placeholder="Укажите причину отклонения..."></textarea>
                </div>
                <div class="d-flex gap-2">
                    @if (Model.App.Status == "pending" && Model.App.RequiresDirector)
                    {
                        <button type="submit" name="decision" value="send_to_director" class="btn btn-primary">
                            &#x2197; Отправить директору
                        </button>
                    }
                    else
                    {
                        <button type="submit" name="decision" value="approved" class="btn btn-success">
                            &#x2713; Одобрить
                        </button>
                    }
                    <button type="submit" name="decision" value="rejected" class="btn btn-danger">
                        &#x2715; Отклонить
                    </button>
                </div>
            </form>
        </div>
    </div>
}
