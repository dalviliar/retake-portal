@page "{id:int}"
@model RetakePortal.Pages.OR.ApplicationDetailModel
@{
    ViewData["Title"] = $"Заявление №{Model.App?.Id}";
}

@if (Model.App == null)
{
    <div class="alert alert-danger">Заявление не найдено.</div>
    <a href="@(Model.ReturnUrl ?? "/OR/Dashboard")" class="btn btn-outline-secondary btn-sm">← Назад</a>
    return;
}

<div class="mb-3">
    <a href="@(Model.ReturnUrl ?? "/OR/Dashboard")" class="text-muted small">← Все заявления</a>
</div>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="fw-bold mb-1">Заявление №@Model.App.Id</h4>
        <span class="badge @Model.App.StatusBadgeClass fs-6">@Model.App.StatusDisplay</span>
    </div>
    <small class="text-muted">@Model.App.SubmittedAt.ToAlmaty() (Алматы)</small>
</div>

@* ── Данные студента (на всю ширину) ── *@
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h6 class="text-muted text-uppercase small mb-3">Данные студента</h6>
        <div class="row">
            <div class="col-md-6">
                <table class="table table-sm table-borderless mb-0">
                    <tr><td class="text-muted" style="width:120px">ИИН</td><td class="font-monospace">@Model.App.IIN</td></tr>
                    <tr><td class="text-muted">ФИО</td><td class="fw-semibold">@Model.App.StudentFullName</td></tr>
                    <tr><td class="text-muted">Институт</td><td>@Model.App.Institute</td></tr>
                </table>
            </div>
            <div class="col-md-6">
                <table class="table table-sm table-borderless mb-0">
                    <tr><td class="text-muted" style="width:120px">Кафедра</td><td>@Model.App.Department</td></tr>
                    <tr><td class="text-muted">Специальность</td><td>@Model.App.Specialty</td></tr>
                    <tr><td class="text-muted">Курс / Уровень</td><td>@Model.App.Course курс, @Model.App.EducationLevelDisplay</td></tr>
                </table>
            </div>
        </div>
    </div>
</div>

@* ── Алерты ── *@
@if (Model.App.ExpulsionConflict)
{
    <div class="alert alert-warning mb-4">
        <strong>⚠ Конфликт:</strong> по одной или нескольким дисциплинам имеется акт нарушения.
        <a asp-page="/OR/ExpelledStudents" class="alert-link ms-2">Открыть список →</a>
    </div>
}
@if (Model.App.Status == "rejected" && !string.IsNullOrEmpty(Model.App.RejectionReason))
{
    <div class="alert alert-danger mb-4">
        <strong>Причина отклонения:</strong> @Model.App.RejectionReason
    </div>
}
@if (Model.App.Status == "pending_director")
{
    <div class="alert alert-info mb-4">
        <strong>Ожидает согласования директора.</strong> После решения директора заявление вернётся сюда.
    </div>
}
@if (Model.App.Status == "director_approved")
{
    <div class="alert alert-primary mb-4">
        <strong>Директор согласовал.</strong> Одобрите дисциплины в таблице ниже.
    </div>
}

@* ── Дисциплины с историей справа ── *@
@{
    bool canActOnItems = Model.App.Status is "pending" or "director_approved";
}

<h6 class="text-muted text-uppercase small mb-3">Дисциплины</h6>

@foreach (var item in Model.App.Items)
{
    var badgeClass = item.Grade switch {
        "F" => "bg-danger",
        "I" => "bg-info text-dark",
        _   => "bg-warning text-dark"
    };

    <div class="card border-0 shadow-sm mb-3">
        <div class="row g-0">

            @* Левая часть: информация о дисциплине + кнопки *@
            <div class="col-md-7 p-3 border-end">
                <div class="d-flex align-items-start justify-content-between mb-2">
                    <div>
                        @if (!string.IsNullOrEmpty(item.DisciplineCode))
                        {
                            <span class="text-muted font-monospace small d-block">@item.DisciplineCode</span>
                        }
                        <span class="fw-semibold">@item.DisciplineName</span>
                    </div>
                    <div class="d-flex align-items-center gap-2 ms-3 flex-shrink-0">
                        <span class="badge @badgeClass">@item.Grade</span>
                        <span class="text-muted small">
                            @(item.TotalCost == 0 ? "Бесплатно" : item.TotalCost.ToString("N0") + " тг")
                        </span>
                    </div>
                </div>

                @* Документы *@
                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(item.ConfirmationDocumentUrl))
                    {
                        <a href="@item.ConfirmationDocumentUrl" target="_blank"
                           class="badge bg-secondary text-decoration-none me-1">Справка</a>
                    }
                    @if (!string.IsNullOrEmpty(item.PaymentReceiptUrl))
                    {
                        <a href="@item.PaymentReceiptUrl" target="_blank"
                           class="badge bg-info text-decoration-none">Чек</a>
                    }
                </div>

                @* Статус и кнопки *@
                <div class="d-flex align-items-center gap-2">
                    <span class="badge @item.ItemStatusBadgeClass">@item.ItemStatusDisplay</span>
                    @if (canActOnItems && item.ItemStatus == "pending")
                    {
                        <form method="post" class="d-inline">
                            <input type="hidden" asp-for="AppId" />
                            <input type="hidden" asp-for="ReturnUrl" />
                            <input type="hidden" name="ItemId" value="@item.Id" />
                            <button type="submit" name="decision" value="approve_item"
                                    class="btn btn-success btn-sm">&#x2713; Одобрить</button>
                        </form>
                        <button type="button" class="btn btn-outline-danger btn-sm"
                                data-bs-toggle="modal" data-bs-target="#rejectModal"
                                data-item-id="@item.Id">&#x2715; Отклонить</button>
                    }
                </div>
            </div>

            @* Правая часть: история рассмотрения этой дисциплины *@
            <div class="col-md-5 p-3 bg-light">
                <p class="text-muted text-uppercase small mb-2">История</p>
                <ul class="list-unstyled mb-0 small">
                    <li class="mb-2">
                        <span class="badge bg-secondary me-1">Подано</span>
                        @Model.App.SubmittedAt.ToAlmaty()
                    </li>
                    @if (item.Grade is "F" or "I" && Model.App.DirectorReviewedAt.HasValue
                         && !string.IsNullOrEmpty(Model.App.DirectorName))
                    {
                        <li class="mb-2">
                            <span class="badge bg-dark me-1">Директор</span>
                            <span class="fw-semibold">@Model.App.DirectorName</span>
                            <span class="text-muted ms-1">@Model.App.DirectorReviewedAt.Value.ToAlmaty()</span>
                            <span class="badge @Model.App.StatusBadgeClass ms-1">@Model.App.StatusDisplay</span>
                        </li>
                    }
                    @if (!string.IsNullOrEmpty(item.ItemReviewedByName) && item.ItemReviewedAt.HasValue)
                    {
                        <li class="mb-2">
                            <span class="badge bg-primary me-1">ОР</span>
                            <span class="fw-semibold">@item.ItemReviewedByName</span>
                            <span class="text-muted ms-1">@item.ItemReviewedAt.Value.ToAlmaty()</span>
                            <span class="badge @item.ItemStatusBadgeClass ms-1">@item.ItemStatusDisplay</span>
                        </li>
                    }
                    else if (item.ItemStatus == "pending")
                    {
                        <li class="text-muted">Ожидает рассмотрения</li>
                    }
                </ul>
            </div>

        </div>
    </div>
}

@* Итого *@
@if (Model.App.TotalAmount > 0)
{
    <div class="text-end fw-bold mb-4">
        Итого: @Model.App.TotalAmount.ToString("N0") тг
    </div>
}

@* Модальное окно отклонения *@
@if (canActOnItems)
{
    <div class="modal fade" id="rejectModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post">
                    <input type="hidden" asp-for="AppId" />
                    <input type="hidden" asp-for="ReturnUrl" />
                    <input type="hidden" name="ItemId" id="rejectItemId" value="" />
                    <div class="modal-header">
                        <h5 class="modal-title">Отклонить заявление</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label class="form-label fw-semibold">Причина отклонения</label>
                        <textarea name="Reason" class="form-control" rows="3"
                                  placeholder="Укажите причину..." required></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" name="decision" value="reject_item" class="btn btn-danger">
                            &#x2715; Отклонить
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script>
        document.getElementById('rejectModal').addEventListener('show.bs.modal', function(e) {
            document.getElementById('rejectItemId').value = e.relatedTarget.dataset.itemId;
        });
    </script>
}

@* Проверка оплаты *@
@if (Model.App.Status == "payment_submitted")
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-3">Проверка оплаты</h6>
            <p class="text-muted small mb-3">
                Студент прикрепил чек(и) об оплате. Чеки доступны в таблице дисциплин выше.
            </p>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
            }
            <form method="post">
                <input type="hidden" asp-for="AppId" />
                <input type="hidden" asp-for="ReturnUrl" />
                <div class="d-flex gap-2">
                    <button type="submit" name="decision" value="verify_payment" class="btn btn-success">
                        &#x2713; Оплата подтверждена — одобрить
                    </button>
                    <button type="submit" name="decision" value="rejected" class="btn btn-danger">
                        &#x2715; Отклонить
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@* Акт нарушения для одобренных *@
@if (Model.App.Status == "approved" && Model.App.ExpulsionConflict)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="AppId" />
                <input type="hidden" asp-for="ReturnUrl" />
                <button type="submit" name="decision" value="rejected" class="btn btn-danger btn-sm">
                    &#x2715; Отклонить (акт нарушения)
                </button>
            </form>
        </div>
    </div>
}

@* Отправить директору (F/I) *@
@if (Model.App.Status == "pending" && Model.App.RequiresDirector)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
            }
            <form method="post">
                <input type="hidden" asp-for="AppId" />
                <input type="hidden" asp-for="ReturnUrl" />
                <button type="submit" name="decision" value="send_to_director" class="btn btn-primary">
                    &#x2197; Отправить директору
                </button>
            </form>
        </div>
    </div>
}
