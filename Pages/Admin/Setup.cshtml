@page
@model RetakePortal.Pages.Admin.SetupModel
@{
    ViewData["Title"] = "Начальная настройка";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        @if (Model.AlreadySetup)
        {
            <div class="alert alert-warning text-center">
                <strong>Настройка уже выполнена.</strong><br />
                Аккаунт администратора уже создан.
                <div class="mt-2">
                    <a asp-page="/Admin/Login" class="btn btn-primary btn-sm">Войти как администратор</a>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-1">Начальная настройка</h5>
                    <p class="text-muted small mb-4">
                        Создайте аккаунт администратора. После входа можно добавлять специалистов и директора.
                    </p>

                    @if (Model.Success)
                    {
                        <div class="alert alert-success">
                            Аккаунт администратора создан! <a asp-page="/Admin/Login">Войти</a>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Логин</label>
                            <input asp-for="Username" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Пароль</label>
                            <input asp-for="Password" type="password" class="form-control" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-semibold">ФИО</label>
                            <input asp-for="FullName" class="form-control" placeholder="Иванов Иван Иванович" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Создать администратора</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
