@page
@model RetakePortal.Pages.Admin.AdminLoginModel
@{ ViewData["Title"] = "Вход администратора"; Layout = "_Layout"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-1">Вход</h5>
                <p class="text-muted small mb-4">Администратор портала</p>
                @if (!string.IsNullOrEmpty(Model.Error))
                {
                    <div class="alert alert-danger py-2">@Model.Error</div>
                }
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label small">Логин</label>
                        <input asp-for="Username" class="form-control" autofocus />
                    </div>
                    <div class="mb-4">
                        <label class="form-label small">Пароль</label>
                        <input asp-for="Password" type="password" class="form-control" />
                    </div>
                    <button class="btn btn-dark w-100">Войти</button>
                </form>
            </div>
        </div>
    </div>
</div>
