@page "{id:int}"
@model RetakePortal.Pages.Director.DirectorApplicationDetailModel
@{ ViewData["Title"] = $"Заявление №{Model.App?.Id}"; Layout = "_Layout"; }

@if (Model.App == null)
{
    <div class="alert alert-danger">Заявление не найдено.</div>
    <a asp-page="/Director/Applications" class="btn btn-outline-secondary btn-sm">← Назад</a>
    return;
}

<div class="mb-3">
    <a asp-page="/Director/Applications" class="text-muted small">← Заявления на согласование</a>
</div>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="fw-bold mb-1">Заявление №@Model.App.Id</h4>
        <span class="badge @Model.App.StatusBadgeClass fs-6">@Model.App.StatusDisplay</span>
    </div>
    <small class="text-muted">@Model.App.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</small>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small mb-3">Данные студента</h6>
                <table class="table table-sm table-borderless mb-0">
                    <tr><td class="text-muted">ИИН</td><td class="font-monospace">@Model.App.IIN</td></tr>
                    <tr><td class="text-muted">ФИО</td><td class="fw-semibold">@Model.App.StudentFullName</td></tr>
                    <tr><td class="text-muted">Институт</td><td>@Model.App.Institute</td></tr>
                    <tr><td class="text-muted">Кафедра</td><td>@Model.App.Department</td></tr>
                    <tr><td class="text-muted">Специальность</td><td>@Model.App.Specialty</td></tr>
                    <tr><td class="text-muted">Курс</td><td>@Model.App.Course</td></tr>
                    <tr><td class="text-muted">Уровень</td><td>@Model.App.EducationLevelDisplay</td></tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small mb-3">Дисциплины</h6>
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Дисциплина</th>
                            <th class="text-center">Оценка</th>
                            <th>Документ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.App.Items)
                        {
                            var badgeClass = item.Grade switch {
                                "F" => "bg-danger",
                                "I" => "bg-info text-dark",
                                _   => "bg-warning text-dark"
                            };
                            <tr>
                                <td>@item.DisciplineName</td>
                                <td class="text-center">
                                    <span class="badge @badgeClass">@item.Grade</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ConfirmationDocumentUrl))
                                    {
                                        <a href="@item.ConfirmationDocumentUrl" target="_blank"
                                           class="badge bg-secondary text-decoration-none">Справка</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h6 class="text-muted text-uppercase small mb-3">История рассмотрения</h6>
        <ul class="list-unstyled mb-0">
            <li class="mb-2">
                <span class="badge bg-secondary me-2">Подано</span>
                <span class="small">@Model.App.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</span>
            </li>
            @if (Model.App.ReviewedAt.HasValue && !string.IsNullOrEmpty(Model.App.ReviewedByName))
            {
                <li class="mb-2">
                    <span class="badge bg-primary me-2">ОР</span>
                    <span class="small fw-semibold">@Model.App.ReviewedByName</span>
                    <span class="text-muted small ms-2">@Model.App.ReviewedAt.Value.ToAlmaty()</span>
                </li>
            }
            @if (Model.App.DirectorReviewedAt.HasValue && !string.IsNullOrEmpty(Model.App.DirectorName))
            {
                <li class="mb-2">
                    <span class="badge bg-dark me-2">Директор</span>
                    <span class="small fw-semibold">@Model.App.DirectorName</span>
                    <span class="text-muted small ms-2">@Model.App.DirectorReviewedAt.Value.ToAlmaty()</span>
                    <span class="badge @Model.App.StatusBadgeClass ms-2">@Model.App.StatusDisplay</span>
                </li>
            }
        </ul>
    </div>
</div>

@if (Model.App.Status == "pending_director")
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-3">Решение директора</h6>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
            }

            <form method="post">
                <input type="hidden" asp-for="AppId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Причина (обязательна при отклонении)</label>
                    <textarea asp-for="Reason" class="form-control" rows="3"
                              placeholder="Укажите причину отклонения..."></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" name="decision" value="approved" class="btn btn-success">
                        &#x2713; Согласовать
                    </button>
                    <button type="submit" name="decision" value="rejected" class="btn btn-danger">
                        &#x2715; Отклонить
                    </button>
                </div>
            </form>
        </div>
    </div>
}
