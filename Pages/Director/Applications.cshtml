@page
@model RetakePortal.Pages.Director.ApplicationsModel
@{ ViewData["Title"] = "Согласование заявлений"; Layout = "_Layout"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Заявления на согласование</h4>
        <p class="text-muted small mb-0">@Model.SpecName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Director/Stats" class="btn btn-outline-secondary btn-sm">Статистика</a>
        <form method="post" asp-page-handler="Logout">
            <button class="btn btn-outline-secondary btn-sm">Выйти</button>
        </form>
    </div>
</div>

@if (!Model.Applications.Any())
{
    <div class="text-center text-muted py-5">Нет заявлений, ожидающих согласования</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>№</th>
                        <th>Студент</th>
                        <th>ИИН</th>
                        <th>Институт</th>
                        <th class="text-center">Курс</th>
                        <th class="text-center">Дисц.</th>
                        <th>Дата</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.Applications)
                    {
                        <tr>
                            <td class="text-muted small">#@app.Id</td>
                            <td class="fw-semibold">@app.StudentFullName</td>
                            <td class="font-monospace small">@app.IIN</td>
                            <td class="small text-muted">@app.Institute</td>
                            <td class="text-center">@app.Course</td>
                            <td class="text-center">@app.Items.Count</td>
                            <td class="small text-muted">@app.SubmittedAt.ToString("dd.MM.yy")</td>
                            <td>
                                <a asp-page="/Director/ApplicationDetail" asp-route-id="@app.Id"
                                   class="btn btn-sm btn-primary">Рассмотреть</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
