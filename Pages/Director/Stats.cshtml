@page
@model RetakePortal.Pages.Director.StatsModel
@{ ViewData["Title"] = "Все заявления"; Layout = "_Layout"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Все заявления</h4>
    <a asp-page="/Director/Applications" class="btn btn-primary btn-sm position-relative">
        На согласование
        @if (Model.PendingDirectorCount > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                @Model.PendingDirectorCount
            </span>
        }
    </a>
</div>

@if (!Model.Applications.Any())
{
    <div class="text-center text-muted py-5">Заявлений нет</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>№</th>
                        <th>Студент</th>
                        <th>ИИН</th>
                        <th>Институт</th>
                        <th class="text-center">Курс</th>
                        <th class="text-center">Дисц.</th>
                        <th class="text-end">Сумма</th>
                        <th class="text-center">Статус</th>
                        <th>Специалист ОР</th>
                        <th>Директор</th>
                        <th>Назначил пересдачу</th>
                        <th>Дата</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.Applications)
                    {
                        <tr>
                            <td class="text-muted small">#@app.Id</td>
                            <td class="fw-semibold">
                                @app.StudentFullName
                                @if (app.ExpulsionConflict)
                                {
                                    <span class="badge bg-warning text-dark ms-1" title="Акт нарушения после одобрения">⚠</span>
                                }
                            </td>
                            <td class="font-monospace small">@app.IIN</td>
                            <td class="small text-muted">@app.Institute</td>
                            <td class="text-center">@app.Course</td>
                            <td class="text-center">@app.Items.Count</td>
                            <td class="text-end fw-semibold">
                                @(app.TotalAmount == 0 ? "Бесплатно" : app.TotalAmount.ToString("N0") + " тг")
                            </td>
                            <td class="text-center">
                                <span class="badge @app.StatusBadgeClass">@app.StatusDisplay</span>
                            </td>
                            <td class="small">
                                @if (!string.IsNullOrEmpty(app.ReviewedByName))
                                {
                                    <span>@app.ReviewedByName</span>
                                    @if (app.ReviewedAt.HasValue)
                                    {
                                        <div class="text-muted">@app.ReviewedAt.Value.ToAlmatyShort()</div>
                                    }
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="small">
                                @if (!string.IsNullOrEmpty(app.DirectorName))
                                {
                                    <span>@app.DirectorName</span>
                                    @if (app.DirectorReviewedAt.HasValue)
                                    {
                                        <div class="text-muted">@app.DirectorReviewedAt.Value.ToAlmatyShort()</div>
                                    }
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="small">
                                @if (!string.IsNullOrEmpty(app.ScheduledByName))
                                {
                                    <span>@app.ScheduledByName</span>
                                    @if (app.ScheduledAt.HasValue)
                                    {
                                        <div class="text-muted">@app.ScheduledAt.Value.ToAlmatyShort()</div>
                                    }
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="small text-muted">@app.SubmittedAt.ToAlmatyShort()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
