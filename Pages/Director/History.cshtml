@page
@model RetakePortal.Pages.Director.DirectorHistoryModel
@{
    ViewData["Title"] = "История решений";
}

<h4 class="fw-bold mb-4">История решений директоров</h4>

@if (!Model.Applications.Any())
{
    <div class="text-center text-muted py-5">Решений ещё не принималось</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>№</th>
                        <th>Студент</th>
                        <th>ИИН</th>
                        <th>Институт</th>
                        <th class="text-center">Дисц.</th>
                        <th class="text-center">Решение</th>
                        <th>Директор</th>
                        <th>Дата решения</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.Applications)
                    {
                        <tr>
                            <td class="text-muted small">#@app.Id</td>
                            <td class="fw-semibold">@app.StudentFullName</td>
                            <td class="font-monospace small">@app.IIN</td>
                            <td class="small text-muted">@app.Institute</td>
                            <td class="text-center">@app.Items.Count</td>
                            <td class="text-center">
                                <span class="badge @app.StatusBadgeClass">@app.StatusDisplay</span>
                            </td>
                            <td class="small">@app.DirectorName</td>
                            <td class="small text-muted">
                                @(app.DirectorReviewedAt.HasValue
                                    ? app.DirectorReviewedAt.Value.ToAlmaty()
                                    : "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
