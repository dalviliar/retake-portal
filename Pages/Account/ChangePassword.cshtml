@page
@model RetakePortal.Pages.Account.ChangePasswordModel
@{ ViewData["Title"] = "Смена пароля"; }

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <h4 class="fw-bold mb-4">Смена пароля</h4>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.Success ? "alert-success" : "alert-danger")">
                @Model.Message
            </div>
        }

        @if (!Model.Success)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Текущий пароль</label>
                            <input asp-for="CurrentPassword" type="password" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Новый пароль</label>
                            <input asp-for="NewPassword" type="password" class="form-control" required minlength="6" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Подтвердите новый пароль</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" required minlength="6" />
                        </div>
                        <button class="btn btn-primary w-100">Изменить пароль</button>
                    </form>
                </div>
            </div>
        }

        <div class="mt-3 text-center">
            <a onclick="history.back()" class="text-muted small" style="cursor:pointer">← Назад</a>
        </div>
    </div>
</div>
